# ---- API ----
NODE_ENV=development
PORT=3000

# ---- Database ----
# The application connects as a superuser/owner for migrations, but the runtime
# uses the least-privilege workshop_app role via SET LOCAL ROLE (see PgService).
DATABASE_URL=postgres://workshop:workshop@localhost:5432/workshop
DB_APP_ROLE=workshop_app

# ---- Auth (OIDC) ----
# Point these at your EU-resident IdP (managed, Keycloak, or Ory).
OIDC_ISSUER=https://id.example.eu/realms/workshop
OIDC_AUDIENCE=workshop-api
OIDC_JWKS_URI=https://id.example.eu/realms/workshop/protocol/openid-connect/certs

# ---- AI Gateway ----
# Must be an EU-resident endpoint when processing PII.
AI_RESIDENCY=eu
AI_PROVIDER_BASE_URL=
AI_DEFAULT_MODEL=

# ---- Outbox worker ----
OUTBOX_POLL_MS=1000
OUTBOX_MAX_ATTEMPTS=12

# ---------------------------------------------------------------------------
# Phase 4A — public origins, OIDC client, and file storage
# ---------------------------------------------------------------------------
# Public base URLs (used for local signed-storage URLs and OIDC redirect origin)
PUBLIC_API_BASE_URL=http://localhost:3000
WEB_APP_BASE_URL=http://localhost:3001

# OIDC client (PUBLIC client; PKCE, no secret). The verifier vars (OIDC_ISSUER,
# OIDC_AUDIENCE, OIDC_JWKS_URI) already exist above.
OIDC_CLIENT_ID=workshop-web
OIDC_SCOPES=openid profile email offline_access
OIDC_REDIRECT_URI=http://localhost:3001/auth/callback
# Discovery document (defaults to <issuer>/.well-known/openid-configuration)
# OIDC_DISCOVERY_URL=

# File storage. STORAGE_DRIVER=s3 (production) or local (development only).
STORAGE_DRIVER=local
SIGNED_URL_TTL_SECONDS=600

# S3-compatible object storage (choose an EU region/endpoint for residency).
S3_BUCKET=
S3_REGION=eu-central-1
# S3_ENDPOINT=            # set for MinIO/OVH/Scaleway; leave empty for AWS
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=true # required by most non-AWS S3 implementations

# Local dev storage driver
LOCAL_STORAGE_DIR=.storage
LOCAL_STORAGE_SIGNING_SECRET=dev-only-secret-change-me
