{
  "name": "@workshop/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared domain core and types (money, RBAC, audit hash-chain, numbering, tenant context). Dependency-free; consumed by API and web.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "require": "./dist/index.js", "default": "./src/index.ts" },
    "./*": { "types": "./dist/*.d.ts", "require": "./dist/*.js", "default": "./src/*" }
  },
  "scripts": {
    "test": "node --experimental-strip-types --import ./test/register-ts.mjs test/run.ts",
    "build": "tsc -p tsconfig.json && node scripts/postbuild.cjs"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "typescript": "^5.6.0"
  }
}
